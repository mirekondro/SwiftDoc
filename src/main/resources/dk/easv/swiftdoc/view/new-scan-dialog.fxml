<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonType?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DialogPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<DialogPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="dk.easv.swiftdoc.controller.NewScanDialogController"
            fx:id="dialogPane"
            styleClass="dialog-root">
    <headerText>Start a New Scan</headerText>
    <contentText>Configure your scanning session and begin digitalization.</contentText>

    <content>
        <VBox spacing="16.0" styleClass="dialog-content">
            <VBox spacing="10.0" styleClass="dialog-card">
                <Label text="Scanning Profile" styleClass="section-title"/>
                <HBox spacing="12.0">
                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                        <Label text="Profile" styleClass="muted"/>
                        <HBox spacing="8.0">
                            <ComboBox fx:id="profileComboBox" promptText="Select a profile..." maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS"/>
                            <Button text="Create" onAction="#onCreateProfile" styleClass="btn"/>
                        </HBox>
                    </VBox>
                    <VBox spacing="6.0" prefWidth="260.0" styleClass="dialog-card">
                        <Label text="Description" styleClass="muted"/>
                        <Label fx:id="profileDescriptionLabel" text="Profile details will appear here" styleClass="dialog-muted" wrapText="true"/>
                    </VBox>
                </HBox>
            </VBox>

            <HBox spacing="12.0">
                <VBox spacing="8.0" HBox.hgrow="ALWAYS" styleClass="dialog-card">
                    <Label text="Box Information" styleClass="section-title"/>
                    <GridPane hgap="8.0" vgap="6.0">
                        <Label text="Box Name" styleClass="muted" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="boxNameTextField" promptText="Enter box name (e.g., 'Inbox 001')" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <Label fx:id="boxNameErrorLabel" text="" style="-fx-text-fill: #cc0000; -fx-font-size: 10;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    </GridPane>
                </VBox>

                <VBox spacing="8.0" prefWidth="260.0" styleClass="dialog-card">
                    <Label text="Scan Options" styleClass="section-title"/>

                    <CheckBox fx:id="duplicateDetectionCheckBox" text="Enable duplicate detection"/>
                    <CheckBox fx:id="separateDocumentsCheckBox" text="Create separate document per page" selected="false"/>
                </VBox>
            </HBox>

            <VBox spacing="8.0" styleClass="dialog-card">
                <Label text="Notes (optional)" styleClass="section-title"/>
                <TextArea fx:id="notesTextArea" prefRowCount="3" wrapText="true" promptText="Add any notes for this scanning session..."/>
            </VBox>
        </VBox>
    </content>

    <buttonTypes>
        <ButtonType fx:id="startScanButtonType" text="Start Scan" buttonData="OK_DONE"/>
        <ButtonType fx:id="previewButtonType" text="Preview Settings" buttonData="OTHER"/>
        <ButtonType fx:id="cancelButtonType" text="Cancel" buttonData="CANCEL_CLOSE"/>
    </buttonTypes>
</DialogPane>

