<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Dialog?>
<?import javafx.scene.control.DialogPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<DialogPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="dk.easv.swiftdoc.controller.NewScanDialogController">
    <headerText>Start a New Scan</headerText>
    <contentText>Configure your scanning session and begin digitalization.</contentText>

    <!-- Main content VBox -->
    <content>
        <VBox spacing="15.0" style="-fx-padding: 15;">

            <!-- Scanning Profile Section -->
            <VBox spacing="8.0" style="-fx-border-color: #e0e0e0; -fx-border-radius: 4; -fx-padding: 10;">
                <Label text="Scanning Profile" style="-fx-font-weight: bold; -fx-font-size: 12;"/>
                <ComboBox fx:id="profileComboBox" prefWidth="300.0" promptText="Select a profile..."/>
                <Label fx:id="profileDescriptionLabel" text="Profile details will appear here" style="-fx-text-fill: #666666; -fx-font-size: 10; -fx-wrap-text: true;" wrapText="true"/>
            </VBox>

            <!-- Box Details Section -->
            <VBox spacing="8.0" style="-fx-border-color: #e0e0e0; -fx-border-radius: 4; -fx-padding: 10;">
                <Label text="Box Information" style="-fx-font-weight: bold; -fx-font-size: 12;"/>
                <VBox spacing="5.0">
                    <Label text="Box Name" style="-fx-font-size: 11;"/>
                    <TextField fx:id="boxNameTextField" promptText="Enter box name (e.g., 'Inbox 001')"/>
                    <Label fx:id="boxNameErrorLabel" text="" style="-fx-text-fill: #cc0000; -fx-font-size: 10;"/>
                </VBox>
            </VBox>

            <!-- Scan Options Section -->
            <VBox spacing="8.0" style="-fx-border-color: #e0e0e0; -fx-border-radius: 4; -fx-padding: 10;">
                <Label text="Scan Options" style="-fx-font-weight: bold; -fx-font-size: 12;"/>
                <CheckBox fx:id="autoSplitCheckBox" text="Auto-split documents by barcode" selected="true"/>
                <CheckBox fx:id="duplicateDetectionCheckBox" text="Enable duplicate detection"/>
                <CheckBox fx:id="separateDocumentsCheckBox" text="Create separate document per page" selected="false"/>
            </VBox>

            <!-- Notes Section -->
            <VBox spacing="8.0" style="-fx-border-color: #e0e0e0; -fx-border-radius: 4; -fx-padding: 10;">
                <Label text="Notes (optional)" style="-fx-font-weight: bold; -fx-font-size: 12;"/>
                <TextArea fx:id="notesTextArea" prefRowCount="3" wrapText="true" promptText="Add any notes for this scanning session..."/>
            </VBox>

        </VBox>
    </content>

    <!-- Dialog buttons -->
    <buttons>
        <Button fx:id="startScanButton" text="Start Scan" style="-fx-padding: 8 25;"/>
        <Button fx:id="cancelButton" text="Cancel"/>
        <Button fx:id="previewButton" text="Preview Settings"/>
    </buttons>
</DialogPane>

