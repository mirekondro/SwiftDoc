<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="dk.easv.swiftdoc.controller.MainController"
      fx:id="root"
      onKeyPressed="#onKeyPressed"
      focusTraversable="true"
      spacing="0.0" prefWidth="1100.0" prefHeight="650.0"
      styleClass="app-root">

    <MenuBar styleClass="app-menubar">
        <Menu text="Export">
            <MenuItem text="Export..." onAction="#onExportMenuCommand"/>
        </Menu>
    </MenuBar>

    <HBox spacing="16.0" styleClass="app-header" alignment="CENTER_LEFT">
        <HBox spacing="10.0" styleClass="app-brand" alignment="CENTER_LEFT">
            <SVGPath content="M12 2l3 6 6 1-4 4 1 6-6-3-6 3 1-6-4-4 6-1z" styleClass="brand-icon"/>
            <VBox spacing="2.0">
                <Label text="SwiftDoc" styleClass="app-title"/>
                <Label text="Scan. Organize. Export." styleClass="app-subtitle"/>
            </VBox>
        </HBox>
        <HBox spacing="10.0" styleClass="header-cards" HBox.hgrow="ALWAYS" alignment="CENTER_RIGHT">
            <VBox spacing="4.0" styleClass="header-card">
                <Label text="Session" styleClass="header-card-title"/>
                <Label fx:id="sessionInfoLabel" text="No active session" wrapText="true" styleClass="header-card-value"/>
            </VBox>
            <VBox spacing="4.0" styleClass="header-card">
                <Label text="Files" styleClass="header-card-title"/>
                <Label fx:id="counterLabel" text="Files scanned: 0" styleClass="header-card-value"/>
            </VBox>
            <ToggleButton fx:id="themeToggle" text="Dark" onAction="#onThemeToggle" styleClass="toggle"/>
        </HBox>
    </HBox>

    <HBox spacing="14.0" VBox.vgrow="ALWAYS" styleClass="app-body">
        <!-- LEFT COLUMN: controls + status + shortcuts -->
        <VBox alignment="TOP_CENTER" spacing="12.0" prefWidth="230.0" styleClass="panel panel-left">
            <VBox spacing="8.0" styleClass="card">
                <Button text="New" onAction="#onNewCommand" maxWidth="Infinity" styleClass="btn">
                    <graphic>
                        <SVGPath content="M10 4h4v6h6v4h-6v6h-4v-6H4v-4h6z" styleClass="icon"/>
                    </graphic>
                </Button>
                <Button text="Save" onAction="#onSaveCommand" maxWidth="Infinity" styleClass="btn btn-accent">
                    <graphic>
                        <SVGPath content="M5 3h14a2 2 0 0 1 2 2v16H3V5a2 2 0 0 1 2-2zm2 2v4h10V5H7zm0 8v6h10v-6H7z" styleClass="icon"/>
                    </graphic>
                </Button>
                <Button fx:id="scanButton" text="Scan" onAction="#onScanCommand"
                        disable="true" maxWidth="Infinity" styleClass="btn btn-primary">
                    <graphic>
                        <SVGPath content="M3 7V3h4v2H5v2H3zm14-4h4v4h-2V5h-2V3zM3 21v-4h2v2h2v2H3zm16-2h2v-2h2v4h-4v-2zM6 11h12v2H6z" styleClass="icon"/>
                    </graphic>
                </Button>
            </VBox>

            <VBox spacing="6.0" styleClass="card">
                <Label text="Status" styleClass="section-title"/>
                <Label fx:id="lastResultLabel" text="" wrapText="true" styleClass="status-pill"/>
            </VBox>

            <VBox spacing="6.0" styleClass="card">
                <Label text="Shortcuts" styleClass="section-title"/>
                <Label text="F1  – New scan&#10;F2  – Scan&#10;PageUp – Previous file&#10;PageDown – Next file&#10;Ctrl+R – Rotate right&#10;Ctrl+L – Rotate left&#10;Ctrl+0 – Reset rotation&#10;Ctrl+S – Export&#10;Ctrl+F – Focus search"
                       wrapText="true" styleClass="muted"/>
            </VBox>
        </VBox>

        <!-- MIDDLE COLUMN: sidebar tree -->
        <VBox spacing="8.0" prefWidth="300.0" styleClass="panel panel-sidebar">
            <HBox alignment="CENTER_LEFT" spacing="6.0">
                <Label text="All boxes" styleClass="section-title"/>
                <Label text="History" styleClass="pill pill-info"/>
            </HBox>

            <!-- Search field for filtering the tree -->
            <HBox spacing="6.0" alignment="CENTER_LEFT">
                <TextField fx:id="sidebarSearchField" promptText="Search boxes, barcodes, files..."
                           HBox.hgrow="ALWAYS"/>
                <Button text="✕" onAction="#onClearSidebarSearch" styleClass="btn"/>
            </HBox>

            <TreeView fx:id="sidebarTree" VBox.vgrow="ALWAYS" showRoot="false" styleClass="app-tree"/>
        </VBox>

        <!-- RIGHT COLUMN: viewer (caption + rotate toolbar + image) -->
        <VBox spacing="10.0" HBox.hgrow="ALWAYS" styleClass="panel panel-viewer">
            <HBox alignment="CENTER_LEFT" spacing="8.0">
                <Label fx:id="viewerCaptionLabel" text="No page to display yet" styleClass="viewer-title"/>
                <Label text="Preview" styleClass="pill pill-accent"/>
            </HBox>

            <!-- Rotate toolbar -->
            <HBox spacing="8.0" styleClass="toolbar">
                <Button text="Rotate left" onAction="#onRotateLeftCommand" styleClass="btn">
                    <graphic>
                        <SVGPath content="M12 5a7 7 0 1 1-6.5 9.5h2.3A5 5 0 1 0 12 7h2V4l-4 3 4 3V7z" styleClass="icon"/>
                    </graphic>
                </Button>
                <Button text="Rotate right" onAction="#onRotateRightCommand" styleClass="btn">
                    <graphic>
                        <SVGPath content="M12 5a7 7 0 1 0 6.5 9.5h-2.3A5 5 0 1 1 12 7h-2V4l4 3-4 3V7z" styleClass="icon"/>
                    </graphic>
                </Button>
                <Button text="Reset" onAction="#onResetRotationCommand" styleClass="btn">
                    <graphic>
                        <SVGPath content="M6 4h12v4H6V4zm0 6h12v10H6V10zm2 2v6h8v-6H8z" styleClass="icon"/>
                    </graphic>
                </Button>
            </HBox>

            <StackPane VBox.vgrow="ALWAYS" styleClass="viewer-surface">
                <ImageView fx:id="pageImageView"
                           preserveRatio="true"
                           pickOnBounds="true"
                           smooth="true"
                           fitWidth="500.0"
                           fitHeight="540.0"/>
            </StackPane>
        </VBox>
    </HBox>
</VBox>
